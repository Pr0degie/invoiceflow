  "components": {
    "schemas": {
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "nullable": true
          },
          "refreshToken": {
            "type": "string",
            "nullable": true
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "user": {
            "$ref": "#/components/schemas/UserDto"
          }
        },
        "additionalProperties": false
      },
      "ChangePasswordDto": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string",
            "nullable": true
          },
          "newPassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateInvoiceRequest": {
        "required": [
          "lineItems",
          "recipientName",
          "senderAddress",
          "senderName"
        ],
        "type": "object",
        "properties": {
          "senderName": {
            "minLength": 1,
            "type": "string"
          },
          "senderAddress": {
            "minLength": 1,
            "type": "string"
          },
          "recipientName": {
            "minLength": 1,
            "type": "string"
          },
          "recipientAddress": {
            "type": "string",
            "nullable": true
          },
          "recipientStreet": {
            "type": "string",
            "nullable": true
          },
          "recipientPostalCode": {
            "type": "string",
            "nullable": true
          },
          "recipientCity": {
            "type": "string",
            "nullable": true
          },
          "recipientCountryCode": {
            "type": "string",
            "nullable": true
          },
          "recipientEmail": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "recipientVatId": {
            "type": "string",
            "nullable": true
          },
          "buyerReference": {
            "type": "string",
            "nullable": true
          },
          "issueDate": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "dueDate": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "serviceDate": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "servicePeriodStart": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "servicePeriodEnd": {
            "type": "string",
            "format": "date",
            "nullable": true
          },
          "lineItems": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateLineItemRequest"
            }
          },
          "taxRate": {
            "maximum": 1,
            "minimum": 0,
            "type": "number",
            "format": "double"
          },
          "currency": {
            "type": "string",
            "nullable": true
          },
          "notes": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateLineItemRequest": {
