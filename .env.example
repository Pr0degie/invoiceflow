# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_starter"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."

# invoice-api (backend — see ../invoice-api/)
# Local dev: docker compose up in ../invoice-api/ (starts on :8080)
# Production: set to Railway URL once deployed
NEXT_PUBLIC_API_BASE_URL="http://localhost:8080"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
