# ============================================================================
# InvoiceFlow Frontend — Environment Variables
# Copy this file to .env and fill in the values for local development.
# ============================================================================

# ── Backend API ─────────────────────────────────────────────────────────────
# URL of the invoice-api backend, used by the Next.js server only (the browser
# always goes through the /api/backend auth proxy).
# Local: docker compose up in ../invoice-api/ (starts on :8080)
# Production (Docker/Coolify): set API_BASE_URL instead — NEXT_PUBLIC_ values
# are inlined at build time and cannot be changed per deployment.
# API_BASE_URL=http://invoice-api:8080
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# ── NextAuth ─────────────────────────────────────────────────────────────────
# JWT signing secret. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Public URL of this frontend app (used by NextAuth for callback URL construction).
# Local: http://localhost:3000   Production: the public app URL behind Coolify
NEXTAUTH_URL=http://localhost:3000
